{
  "name": "kanonv2",
  "version": "0.1.0",
  "private": true,
  "description": "W3C-compliant SSI protocol with two-tier credential gating (one-time-use + Halo2-KZG SNARK). Phase 1 implementation.",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "lint": "solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean && rm -rf cache artifacts typechain-types",
    "deploy:local": "hardhat run scripts/deploy.ts --network besu-local",
    "seed:local": "hardhat run scripts/seed-dev-data.ts --network besu-local",
    "size": "hardhat size-contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.6.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "chai": "^4.5.0",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.10",
    "snarkjs": "^0.7.6",
    "solhint": "^5.0.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.1.0",
    "@zk-kit/imt": "2.0.0-beta.5",
    "@zk-kit/imt.sol": "2.0.0-beta.12"
  }
}
